{
  "semantic-memory": {
    "command": "node",
    "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"],
    "env": {
      "SEMANTIC_MEMORY_PG_URL": "${SEMANTIC_MEMORY_PG_URL:-postgresql://localhost:5432/semantic_memory}",
      "SEMANTIC_MEMORY_EMBEDDING_MODEL": "${SEMANTIC_MEMORY_EMBEDDING_MODEL:-all-MiniLM-L6-v2}",
      "SEMANTIC_MEMORY_CHUNK_SIZE": "${SEMANTIC_MEMORY_CHUNK_SIZE:-500}"
    }
  }
}
